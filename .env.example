SITE_URL=http://127.0.0.1:8080
REQUEST_TOKEN=request_token
BOT_TOKEN=

TBANK_TERMINAL_ID=1234567890
TBANK_TERMINAL_PASSWORD=terminal_password
# В URL успеха можно использовать плейсхолдер {task_id} — он будет заменён на id задачи (если плейсхолдера нет, строка не меняется).
TBANK_USE_SUCCESS_PAYMENT_REDIRECT_URL=https://my-site/task/{task_id}/success/
TBANK_USE_FAIL_PAYMENT_REDIRECT_URL=https://my-site/error.html

YOOKASSA_ACCOUNT_ID="account_id"
YOOKASSA_TOKEN="live_token"
YOOKASSA_USE_SUCCESS_PAYMENT_REDIRECT_URL="https://my-site/task/{task_id}/success/"

PLANFIX_ACCOUNT=aspectgroup
PLANFIX_TOKEN=planfix_token
DEFAULT_PAYMENT_DEADLINE=30
DEFAULT_RATE_LIMIT=50/minute

# WATA
WATA_TOKEN=
WATA_USE_SUCCESS_PAYMENT_REDIRECT_URL=https://my-site/task/{task_id}/success/
WATA_USE_FAIL_PAYMENT_REDIRECT_URL=https://my-site/error.html

# S3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT_URL=https://storage.yandexcloud.net/
